# Plantilla de variables de entorno.
# Cópiala a .env y rellena los valores:  cp .env.example .env
#
# docker compose la carga automáticamente para sustituir ${VAR} y, además,
# se inyecta en los contenedores mediante 'env_file' (ver docker-compose.yml).

# --- llama-server ---
# Nombre del modelo .gguf dentro de ./models
LLAMA_MODEL=model.gguf

# --- metapod ---
# URL (con esquema y path) a la que metapod hace POST con el resultado del flujo
CALLBACK_URL=

# --- Gemini (metapod + profanity) ---
# API key de Google Gemini. Obligatoria para AnalyzeImage del servicio profanity.
GEMINI_API_KEY=

# --- gateway ---
# Si se define (no vacío), el gateway exige la cabecera X-API-Key en metapod y profanity.
GATEWAY_API_KEY=
